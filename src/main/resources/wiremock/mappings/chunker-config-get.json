{
  "name": "chunker-config-get",
  "request": {
    "method": "POST",
    "urlPath": "/ai.pipestream.opensearch.v1.ChunkerConfigService/GetChunkerConfig"
  },
  "response": {
    "status": 200,
    "headers": {
      "grpc-status-name": "OK"
    },
    "jsonBody": {
      "config": {
        "id": "chunk-1",
        "name": "Recursive Character Chunker",
        "config_id": "token-body-512-50",
        "config_json": {
          "fields": {
            "algorithm": {
              "string_value": "recursive"
            },
            "chunk_size": {
              "number_value": 1000
            },
            "chunk_overlap": {
              "number_value": 200
            }
          }
        }
      }
    }
  }
}
